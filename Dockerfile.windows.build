FROM docker.io/batonogov/pyinstaller-windows:v4.0.1

# Copy all project files into the container
COPY . /src/

# Set working directory to source
WORKDIR /src

# Install additional system dependencies if needed (via apt-get in Wine context)
# Note: The original entrypoint.sh runs pip and pyinstaller through Wine

# Run PyInstaller using the container's entrypoint (runs through Wine for Windows .exe)
ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]