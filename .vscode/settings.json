{
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python.defaultInterpreterPath": "./.venv/bin/python",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.wine": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/backups": true,
        "**/dist_windows": true,
        "**/.kilocode": true,
        "**/.opencode": true,
        "**/build_wine": true,
        "**/dist": true,
        "**/outdir": true,
        "**/folders.db": true,
        "**/folders.db.*": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/.git": true,
        "**/.wine": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/backups": true,
        "**/dist_windows": true,
        "**/.kilocode": true,
        "**/.opencode": true,
        "**/build_wine": true,
        "**/dist": true,
        "**/outdir": true,
        "**/folders.db": true,
        "**/folders.db.*": true
    },
    "python.analysis.exclude": [
        "**/.wine",
        "**/__pycache__",
        "**/backups",
        "**/dist_windows",
        "**/.kilocode",
        "**/.opencode",
        "**/build_wine",
        "**/dist",
        "**/outdir",
        "**/folders.db",
        "**/folders.db.*"
    ],
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/.wine/**": true,
        "**/backups/**": true,
        "**/dist_windows/**": true,
        "**/.opencode/**": true,
        "**/build_wine/**": true,
        "**/dist/**": true,
        "**/outdir/**": true,
        "**/folders.db": true,
        "**/folders.db.*": true
    },
    "search.followSymlinks": false
}